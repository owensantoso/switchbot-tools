#!/bin/zsh
set -euo pipefail

ENV_FILE="${HOME}/.switchbot.env"
SCRIPT_PATH="${0:A}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
CLI_CLOUD="${REPO_ROOT}/scripts/switchbot_cli.py"
CLI_LOCAL="${REPO_ROOT}/scripts/switchbot_ble.py"
CLI_DAEMON="${REPO_ROOT}/scripts/switchbot_ble_daemon.py"
if [[ -x "${REPO_ROOT}/.venv/bin/python" ]]; then
  PYTHON_BIN="${REPO_ROOT}/.venv/bin/python"
else
  PYTHON_BIN="${PYTHON:-python3}"
fi

if [[ -f "${ENV_FILE}" ]]; then
  source "${ENV_FILE}"
fi

show_help() {
  cat <<'EOF'
switchbot-tools controls SwitchBot devices from the terminal.

Usage:
  switchbot-tools <command> [options]

Core commands:
  lights <action>             Control all SwitchBot lights
  device <device> <action>    Control one device by id or name
  scenes list                 List manual scenes
  scenes run <scene>          Run a manual scene by name
  devices [list]              List account devices
  config <action>             Show or create the local env config
  doctor                      Check local setup
  raw <args...>               Pass through to scripts/switchbot_cli.py

Light actions:
  on | off | resume | toggle | status
  purple | red | green | blue | pink | orange | cyan | gold | yellow | rainbow
  white | warm-white | soft-white | neutral-white | cool-white | daylight
  rgb R G B                   Set an RGB color on all lights
  temp K                      Set color temperature, 2700-6500
  brightness N                Set brightness, 1-100
  scan                        Scan nearby BLE devices with --ble

Options:
  --ble, -b     Use direct Bluetooth instead of the SwitchBot cloud API
  --discover    Refresh the BLE device cache before running a local command
  --max         Shortcut for --brightness 100
  --verbose, -v Print BLE timing diagnostics to stderr
  --jsonl-path  Write BLE timing events to a specific JSONL file
  --no-daemon   Bypass the persistent BLE daemon and call the direct BLE CLI
  --parallel N  Set BLE concurrency (default: ${SWITCHBOT_BLE_PARALLEL:-6})
  --exclude-address MAC
               Skip a specific BLE device address in all-lights mode
  --help        Show this help

Examples:
  switchbot-tools lights warm-white --brightness 60
  switchbot-tools lights rgb 255 120 0
  switchbot-tools device "Desk lamp" brightness 35
  switchbot-tools scenes run "Movie mode"
  switchbot-tools config init

Compatibility:
  sblights <action> is an alias for switchbot-tools lights <action>.
EOF
}

show_config_sample() {
  cat <<'EOF'
export SWITCHBOT_TOKEN="your-token"
export SWITCHBOT_SECRET="your-secret"
EOF
}

run_doctor() {
  echo "switchbot-tools doctor"
  echo
  echo "Repo: ${REPO_ROOT}"
  echo "Python: ${PYTHON_BIN}"
  if command -v "${PYTHON_BIN}" >/dev/null 2>&1 || [[ -x "${PYTHON_BIN}" ]]; then
    "${PYTHON_BIN}" --version
  else
    echo "Missing Python: ${PYTHON_BIN}"
  fi
  [[ -f "${CLI_CLOUD}" ]] && echo "Cloud CLI: ok" || echo "Cloud CLI: missing"
  [[ -f "${CLI_LOCAL}" ]] && echo "BLE CLI: ok" || echo "BLE CLI: missing"
  [[ -f "${ENV_FILE}" ]] && echo "Config: ${ENV_FILE}" || echo "Config: missing (${ENV_FILE})"
  [[ -n "${SWITCHBOT_TOKEN:-}" ]] && echo "SWITCHBOT_TOKEN: set" || echo "SWITCHBOT_TOKEN: missing"
  [[ -n "${SWITCHBOT_SECRET:-}" ]] && echo "SWITCHBOT_SECRET: set" || echo "SWITCHBOT_SECRET: missing"
  if "${PYTHON_BIN}" -c "import switchbot" >/dev/null 2>&1; then
    echo "BLE package: ok"
  else
    echo "BLE package: missing or unavailable"
  fi
}

if [[ "${1:-}" == "lights" ]]; then
  shift
elif [[ "${1:-}" == "devices" ]]; then
  shift
  if [[ "${1:-}" == "list" ]]; then
    shift
  fi
  "${PYTHON_BIN}" "${CLI_CLOUD}" devices "$@"
  exit 0
elif [[ "${1:-}" == "scenes" ]]; then
  shift
  case "${1:-list}" in
    list)
      shift || true
      "${PYTHON_BIN}" "${CLI_CLOUD}" scenes "$@"
      ;;
    run)
      shift
      if [[ $# -eq 0 ]]; then
        echo "Usage: switchbot-tools scenes run \"Scene Name\"" >&2
        exit 1
      fi
      "${PYTHON_BIN}" "${CLI_CLOUD}" scene-name "$*"
      ;;
    *)
      echo "Usage: switchbot-tools scenes list|run \"Scene Name\"" >&2
      exit 1
      ;;
  esac
  exit 0
elif [[ "${1:-}" == "device" ]]; then
  shift
  if [[ $# -lt 2 ]]; then
    echo "Usage: switchbot-tools device <device-id-or-name> status|on|off|toggle|brightness|temp|color ..." >&2
    exit 1
  fi
  device="$1"
  action="$2"
  shift 2
  case "${action}" in
    status)
      "${PYTHON_BIN}" "${CLI_CLOUD}" status "${device}"
      ;;
    on|off|toggle)
      "${PYTHON_BIN}" "${CLI_CLOUD}" "${action}" "${device}"
      ;;
    brightness)
      "${PYTHON_BIN}" "${CLI_CLOUD}" brightness "${device}" "$@"
      ;;
    temp)
      "${PYTHON_BIN}" "${CLI_CLOUD}" temp "${device}" "$@"
      ;;
    color)
      "${PYTHON_BIN}" "${CLI_CLOUD}" color "${device}" "$@"
      ;;
    *)
      echo "Unknown device action: ${action}" >&2
      exit 1
      ;;
  esac
  exit 0
elif [[ "${1:-}" == "scene" ]]; then
  shift
  if [[ "${1:-}" == "list" ]]; then
    shift
    "${PYTHON_BIN}" "${CLI_CLOUD}" scenes "$@"
    exit 0
  fi
  if [[ "${1:-}" == "run" ]]; then
    shift
  fi
  if [[ $# -eq 0 ]]; then
    echo "Usage: switchbot-tools scene \"Scene Name\"" >&2
    exit 1
  fi
  if [[ -f "${ENV_FILE}" ]]; then
    source "${ENV_FILE}"
  fi
  "${PYTHON_BIN}" "${CLI_CLOUD}" scene-name "$*"
  exit 0
elif [[ "${1:-}" == "dim" ]]; then
  shift
  if [[ -f "${ENV_FILE}" ]]; then
    source "${ENV_FILE}"
  fi
  "${PYTHON_BIN}" "${CLI_CLOUD}" scene-name "Dim lights"
  exit 0
elif [[ "${1:-}" == "status" ]]; then
  shift
  if [[ $# -eq 0 ]]; then
    echo "Usage: switchbot-tools status <device-id-or-name>" >&2
    exit 1
  fi
  "${PYTHON_BIN}" "${CLI_CLOUD}" status "$@"
  exit 0
elif [[ "${1:-}" == "config" ]]; then
  shift
  case "${1:-path}" in
    path)
      echo "${ENV_FILE}"
      ;;
    sample)
      show_config_sample
      ;;
    init)
      if [[ -f "${ENV_FILE}" ]]; then
        echo "Config already exists: ${ENV_FILE}"
        exit 0
      fi
      umask 077
      show_config_sample > "${ENV_FILE}"
      echo "Created ${ENV_FILE}"
      ;;
    *)
      echo "Usage: switchbot-tools config init|path|sample" >&2
      exit 1
      ;;
  esac
  exit 0
elif [[ "${1:-}" == "doctor" ]]; then
  shift
  run_doctor
  exit 0
elif [[ "${1:-}" == "version" ]]; then
  shift
  if git -C "${REPO_ROOT}" rev-parse --short HEAD >/dev/null 2>&1; then
    echo "switchbot-tools $(git -C "${REPO_ROOT}" rev-parse --short HEAD)"
  else
    echo "switchbot-tools"
  fi
  exit 0
elif [[ "${1:-}" == "raw" ]]; then
  shift
  if [[ -f "${ENV_FILE}" ]]; then
    source "${ENV_FILE}"
  fi
  "${PYTHON_BIN}" "${CLI_CLOUD}" "$@"
  exit 0
elif [[ "${1:-}" == "ble-daemon" ]]; then
  shift
  if [[ "${1:-}" == "start" ]]; then
    shift
    "${PYTHON_BIN}" "${CLI_DAEMON}" status --autostart "$@"
  else
    "${PYTHON_BIN}" "${CLI_DAEMON}" "$@"
  fi
  exit $?
fi

local_mode=0
discover_mode=0
max_mode=0
verbose_mode=0
no_daemon_mode=0
jsonl_path=""
ble_parallel="${SWITCHBOT_BLE_PARALLEL:-6}"
exclude_args=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --ble|-b|--local)
      local_mode=1
      shift
      ;;
    --discover)
      discover_mode=1
      shift
      ;;
    --max)
      max_mode=1
      shift
      ;;
    --verbose|-v|--debug)
      verbose_mode=1
      shift
      ;;
    --no-daemon)
      no_daemon_mode=1
      shift
      ;;
    --jsonl-path)
      if [[ $# -lt 2 ]]; then
        echo "Usage: --jsonl-path <path>" >&2
        exit 1
      fi
      jsonl_path="$2"
      shift 2
      ;;
    --parallel)
      if [[ $# -lt 2 ]]; then
        echo "Usage: --parallel <n>" >&2
        exit 1
      fi
      ble_parallel="$2"
      shift 2
      ;;
    --exclude-address)
      if [[ $# -lt 2 ]]; then
        echo "Usage: --exclude-address <mac>" >&2
        exit 1
      fi
      exclude_args+=(--exclude-address "$2")
      shift 2
      ;;
    --help|-h|help)
      show_help
      exit 0
      ;;
    *)
      break
      ;;
  esac
done

cmd="${1:-}"
if [[ -z "${cmd}" ]]; then
  show_help >&2
  exit 1
fi
shift

extra_args=()
for arg in "$@"; do
  if [[ "${arg}" == "--max" ]]; then
    max_mode=1
    continue
  fi
  extra_args+=("${arg}")
done
if [[ "${max_mode}" -eq 1 && "${cmd}" != "rgb" && "${cmd}" != "temp" && "${cmd}" != "brightness" ]]; then
  extra_args=(--brightness 100 "${extra_args[@]}")
fi
if [[ "${max_mode}" -eq 1 && "${cmd}" == "brightness" && ${#extra_args[@]} -eq 0 ]]; then
  extra_args=(100)
fi

if [[ "${local_mode}" -eq 1 ]]; then
  discover_args=()
  if [[ "${discover_mode}" -eq 1 ]]; then
    discover_args+=(--discover)
  fi
  debug_args=()
  if [[ "${verbose_mode}" -eq 1 ]]; then
    debug_args+=(--verbose)
  fi
  if [[ -n "${jsonl_path}" ]]; then
    debug_args+=(--jsonl-path "${jsonl_path}")
  fi
  daemon_args=(--parallel "${ble_parallel}" --autostart "${discover_args[@]}" "${debug_args[@]}" "${exclude_args[@]}")
  direct_args=(--parallel "${ble_parallel}" "${discover_args[@]}" "${debug_args[@]}" "${exclude_args[@]}")

  case "${cmd}" in
    purple)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all color --r 128 --g 0 --b 128 "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all color --r 128 --g 0 --b 128 "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    white)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all temp --value 4000 "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all temp --value 4000 "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    warm-white|warm)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all temp --value 2700 "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all temp --value 2700 "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    soft-white)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all temp --value 3000 "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all temp --value 3000 "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    neutral-white)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all temp --value 4000 "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all temp --value 4000 "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    cool-white|cool)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all temp --value 5500 "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all temp --value 5500 "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    daylight)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all temp --value 6500 "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all temp --value 6500 "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    gold|yellow)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all color --r 255 --g 190 --b 0 "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all color --r 255 --g 190 --b 0 "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    red)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all color --r 255 --g 0 --b 0 "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all color --r 255 --g 0 --b 0 "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    green)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all color --r 0 --g 180 --b 80 "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all color --r 0 --g 180 --b 80 "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    blue)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all color --r 0 --g 90 --b 255 "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all color --r 0 --g 90 --b 255 "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    pink)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all color --r 255 --g 80 --b 180 "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all color --r 255 --g 80 --b 180 "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    orange)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all color --r 255 --g 120 --b 0 "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all color --r 255 --g 120 --b 0 "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    cyan)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all color --r 0 --g 200 --b 255 "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all color --r 0 --g 200 --b 255 "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    rgb)
      if [[ ${#extra_args[@]} -lt 3 ]]; then
        echo "Usage: switchbot-tools lights rgb R G B" >&2
        exit 1
      fi
      remaining_args=("${extra_args[@]:3}")
      if [[ "${max_mode}" -eq 1 ]]; then
        remaining_args=(--brightness 100 "${remaining_args[@]}")
      fi
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all color --r "${extra_args[1]}" --g "${extra_args[2]}" --b "${extra_args[3]}" "${direct_args[@]}" "${remaining_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all color --r "${extra_args[1]}" --g "${extra_args[2]}" --b "${extra_args[3]}" "${daemon_args[@]}" "${remaining_args[@]}"
      fi
      ;;
    temp)
      if [[ ${#extra_args[@]} -lt 1 ]]; then
        echo "Usage: switchbot-tools lights temp K" >&2
        exit 1
      fi
      remaining_args=("${extra_args[@]:1}")
      if [[ "${max_mode}" -eq 1 ]]; then
        remaining_args=(--brightness 100 "${remaining_args[@]}")
      fi
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all temp --value "${extra_args[1]}" "${direct_args[@]}" "${remaining_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all temp --value "${extra_args[1]}" "${daemon_args[@]}" "${remaining_args[@]}"
      fi
      ;;
    brightness)
      if [[ ${#extra_args[@]} -lt 1 ]]; then
        echo "Usage: switchbot-tools lights brightness N" >&2
        exit 1
      fi
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all brightness --value "${extra_args[1]}" "${direct_args[@]}" "${extra_args[@]:1}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all brightness --value "${extra_args[1]}" "${daemon_args[@]}" "${extra_args[@]:1}"
      fi
      ;;
    off)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all off "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all off "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    on)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all on "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all on "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    resume)
      if [[ "${no_daemon_mode}" -eq 1 ]]; then
        "${PYTHON_BIN}" "${CLI_LOCAL}" all on "${direct_args[@]}" "${extra_args[@]}"
      else
        "${PYTHON_BIN}" "${CLI_DAEMON}" all on "${daemon_args[@]}" "${extra_args[@]}"
      fi
      ;;
    toggle)
      echo "Toggle is only available via the cloud SwitchBot API right now." >&2
      exit 2
      ;;
    status)
      echo "Status is only available via the cloud SwitchBot API right now." >&2
      exit 2
      ;;
    scan)
      "${PYTHON_BIN}" "${CLI_LOCAL}" scan "${debug_args[@]}" "${extra_args[@]}"
      ;;
    dim|scene|rainbow)
      echo "Scenes are only available via the cloud SwitchBot API, not direct BLE." >&2
      exit 2
      ;;
    *)
      show_help >&2
      exit 1
      ;;
  esac
  exit 0
fi

if [[ -z "${SWITCHBOT_TOKEN:-}" || -z "${SWITCHBOT_SECRET:-}" ]]; then
  echo "Missing SwitchBot credentials in ${ENV_FILE}" >&2
  exit 2
fi

case "${cmd}" in
  purple)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-purple --parallel 8 "${extra_args[@]}"
    ;;
  white)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-white --parallel 8 "${extra_args[@]}"
    ;;
  warm-white|warm)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-warm-white --parallel 8 "${extra_args[@]}"
    ;;
  soft-white)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-soft-white --parallel 8 "${extra_args[@]}"
    ;;
  neutral-white)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-neutral-white --parallel 8 "${extra_args[@]}"
    ;;
  cool-white|cool)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-cool-white --parallel 8 "${extra_args[@]}"
    ;;
  daylight)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-daylight --parallel 8 "${extra_args[@]}"
    ;;
  gold|yellow)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-gold --parallel 8 "${extra_args[@]}"
    ;;
  red)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-color 255 0 0 --parallel 8 "${extra_args[@]}"
    ;;
  green)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-color 0 180 80 --parallel 8 "${extra_args[@]}"
    ;;
  blue)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-color 0 90 255 --parallel 8 "${extra_args[@]}"
    ;;
  pink)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-color 255 80 180 --parallel 8 "${extra_args[@]}"
    ;;
  orange)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-color 255 120 0 --parallel 8 "${extra_args[@]}"
    ;;
  cyan)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-color 0 200 255 --parallel 8 "${extra_args[@]}"
    ;;
  rgb)
    if [[ ${#extra_args[@]} -lt 3 ]]; then
      echo "Usage: switchbot-tools lights rgb R G B" >&2
      exit 1
    fi
    remaining_args=("${extra_args[@]:3}")
    if [[ "${max_mode}" -eq 1 ]]; then
      remaining_args=(--brightness 100 "${remaining_args[@]}")
    fi
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-color "${extra_args[1]}" "${extra_args[2]}" "${extra_args[3]}" --parallel 8 "${remaining_args[@]}"
    ;;
  temp)
    if [[ ${#extra_args[@]} -lt 1 ]]; then
      echo "Usage: switchbot-tools lights temp K" >&2
      exit 1
    fi
    remaining_args=("${extra_args[@]:1}")
    if [[ "${max_mode}" -eq 1 ]]; then
      remaining_args=(--brightness 100 "${remaining_args[@]}")
    fi
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-temp "${extra_args[1]}" --parallel 8 "${remaining_args[@]}"
    ;;
  brightness)
    if [[ ${#extra_args[@]} -lt 1 ]]; then
      echo "Usage: switchbot-tools lights brightness N" >&2
      exit 1
    fi
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-brightness "${extra_args[1]}" --parallel 8 "${extra_args[@]:1}"
  rainbow)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-rainbow --parallel 8 "${extra_args[@]}"
    ;;
  off)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-off --parallel 8 "${extra_args[@]}"
    ;;
  on)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-on --parallel 8 "${extra_args[@]}"
    ;;
  resume)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-on --parallel 8 "${extra_args[@]}"
    ;;
  toggle)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-toggle --parallel 8 "${extra_args[@]}"
    ;;
  status)
    "${PYTHON_BIN}" "${CLI_CLOUD}" all-status --parallel 8 "${extra_args[@]}"
    ;;
  dim)
    "${PYTHON_BIN}" "${CLI_CLOUD}" scene-name "Dim lights"
    ;;
  scene)
    if [[ ${#extra_args[@]} -eq 0 ]]; then
      echo "Usage: switchbot-tools scene \"Scene Name\"" >&2
      exit 1
    fi
    "${PYTHON_BIN}" "${CLI_CLOUD}" scene-name "${extra_args[*]}"
    ;;
  devices)
    "${PYTHON_BIN}" "${CLI_CLOUD}" devices "${extra_args[@]}"
    ;;
  *)
    show_help >&2
    exit 1
    ;;
esac
